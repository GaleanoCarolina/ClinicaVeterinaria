<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- Cambie Password por la clave del usuario MySQL local que utilizará la aplicación. -->
    <add name="ClinicaDb"
         connectionString="Server=localhost;Port=3306;Database=clinica_veterinaria;Uid=clinica_app;Pwd=CambieEstaClaveMySQL!;SslMode=Preferred;AllowUserVariables=True;CharSet=utf8mb4;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="NombreClinica" value="Clínica Veterinaria" />
  </appSettings>
</configuration>
